{
  "name": "@veldica/publishready-mcp",
  "version": "1.0.6",
  "mcpName": "io.github.veldica/publishready",
  "description": "MCP server for AI writing quality, revision comparison, readability analysis, and fact-preserving publish-ready editing guidance.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "publishready-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.0",
    "@veldica/publishready-core": "^1.0.6",
    "@veldica/publishready-schemas": "^1.0.6",
    "express": "^5.2.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "ai-writing",
    "writing-tools",
    "editing",
    "readability",
    "revision-analysis",
    "content-quality",
    "fact-preservation",
    "publishing",
    "publish-ready"
  ],
  "license": "MIT",
  "author": "Writing Metrics MCP Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/veldica/publishready-mcp.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/veldica/publishready-mcp/issues"
  },
  "homepage": "https://veldica.com/publish-ready",
  "files": [
    "dist",
    "mcp-server.json",
    ".well-known"
  ]
}
