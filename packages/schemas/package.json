{
  "name": "@veldica/publishready-schemas",
  "version": "1.0.1",
  "description": "PublishReady: Unified Zod schemas and explicit interfaces",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "readability",
    "writing-metrics",
    "text-analysis",
    "zod",
    "schemas"
  ],
  "license": "MIT",
  "author": "Writing Metrics MCP Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/veldica/publishready-mcp.git",
    "directory": "packages/schemas"
  },
  "bugs": {
    "url": "https://github.com/veldica/publishready-mcp/issues"
  },
  "homepage": "https://veldica.com/publish-ready",
  "files": [
    "dist"
  ]
}
